generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
}

model Autopilot {
  id                  String   @id @default(cuid())
  dealId              String   @unique
  renewWhenEpochsLeft Int      @default(100000)
  maxPriceUsdc        Float    @default(1.00)
  webhookUrl          String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  renewals RenewalHistory[]
}

model RenewalHistory {
  id              String    @id @default(cuid())
  dealId          String
  txHash          String
  lighthouseJobId String
  receiptCid      String?
  epochAtRenewal  Int
  createdAt       DateTime  @default(now())

  autopilot Autopilot @relation(fields: [dealId], references: [dealId])
}
