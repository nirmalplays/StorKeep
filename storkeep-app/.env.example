# ── Filecoin ──────────────────────────────────────────────────────────────────
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
STORKEEP_REGISTRY_CONTRACT=0x_YOUR_DEPLOYED_ADDRESS
FILECOIN_WALLET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY

# ── Lighthouse RaaS ───────────────────────────────────────────────────────────
LIGHTHOUSE_RAAS_CONTRACT=0x4015c3E5453d38Df71539C0F7440603C69784d7a

# ── x402 / Coinbase CDP ───────────────────────────────────────────────────────
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret
STORKEEP_WALLET_ADDRESS=0x_YOUR_RECEIVING_WALLET

# ── Vercel Cron Security ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_32_char_secret

# ── Database (Vercel Postgres) ────────────────────────────────────────────────
POSTGRES_PRISMA_URL=postgresql://...
POSTGRES_URL_NON_POOLING=postgresql://...

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://storkeep.vercel.app

# ── Agent Vault /economy (uses storkeep-sdk AgentVault + Synapse) ─────────────
# Uses FILECOIN_WALLET_PRIVATE_KEY if FILECOIN_PRIVATE_KEY is unset.
GEMINI_API_KEY=your_gemini_api_key
FILECOIN_PRIVATE_KEY=
FILECOIN_PIN_TOKEN=
