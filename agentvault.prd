## 2. Agent Types

### Producer Agent
**Goal:** Store datasets on Filecoin via Synapse SDK. Earn USDFC when others retrieve their data.

```typescript
// agents/producer.ts
import { AgentVault } from 'storkeep-sdk'

async function runProducer(vault: AgentVault) {
  // Generate a synthetic dataset (structured JSON)
  const dataset = generateDataset()

  // Store on Filecoin via Synapse SDK
  const { cid } = await vault.store(dataset, {
    ttl:        '30d',
    redundancy: 2,
    tag:        'producer-dataset',
  })

  // Announce availability to the economy (write to onchain registry)
  await vault.announce(cid, { pricePerRetrieve: '0.003' })  // USDFC

  // Collect revenue every cycle
  while (vault.isAlive()) {
    await sleep(CYCLE_MS)
    const earnings = await vault.collectRevenue()
    console.log(`Earned ${earnings} USDFC`)
  }
}
```

### Consumer Agent
**Goal:** Retrieve datasets from Producers. Pay per retrieval. Die when budget hits zero.

```typescript
// agents/consumer.ts
async function runConsumer(vault: AgentVault) {
  while (vault.isAlive()) {
    const available = await vault.discover()      // find datasets onchain
    const cheapest  = available.sort((a,b) => a.price - b.price)[0]

    if (cheapest && await vault.canAfford(cheapest.price)) {
      const data = await vault.retrieve(cheapest.cid)  // Synapse SDK download
      // payment flows automatically — vault.retrieve() handles USDFC transfer
    }

    await sleep(CYCLE_MS)
  }
  // vault.isAlive() returns false when budget < MIN_BALANCE
  // triggers onchain "death" event + prune all stored data
}
```

### Guardian Agent
**Goal:** Watch CIDs for availability. Re-pin dark data to Filecoin Pin. Charge a fee.

```typescript
// agents/guardian.ts
async function runGuardian(vault: AgentVault) {
  const watched = await vault.getWatchList()      // CIDs from the registry

  while (vault.isAlive()) {
    for (const cid of watched) {
      const alive = await vault.checkAvailability(cid)  // IPFS gateway check

      if (!alive) {
        // Re-pin via Filecoin Pin
        await vault.repin(cid)
        // Charge the CID's registered owner
        await vault.chargeRescue(cid, RESCUE_FEE)
        emit('agent:repin', { agentId: vault.id, cid })
      }
    }
    await sleep(GUARDIAN_CYCLE_MS)
  }
}
```

