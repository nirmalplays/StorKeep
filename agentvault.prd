### 1.2 The Neural Network Metaphor — Exact Visual Spec

**Library:** `react-force-graph-2d` (npm: `react-force-graph-2d`, 26k downloads/week, MIT)
WebGL-accelerated canvas rendering. Supports live node/link updates via mutable graphData refs.

**Node types and visual encoding:**

| Agent Type | Shape | Base Color | Size Rule | Pulse |
|-----------|-------|-----------|-----------|-------|
| Producer | Circle | `#00ff88` — electric green | Grows as stored data increases | Pulses when earning |
| Consumer | Circle | `#4488ff` — cobalt | Shrinks as budget depletes | Pulses when paying |
| Guardian | Diamond (custom canvas) | `#ff8800` — amber | Fixed | Pulses when re-pinning |
| Filecoin Node | Hexagon (custom canvas) | `#0090ff` — Filecoin blue | Fixed, large, center gravity | Steady slow pulse |
| Dead agent | Circle | `#333333` — dim gray | Final size frozen | No pulse — fades to ghost |

**Node size formula for Consumers:**
```
radius = 6 + (budgetRemaining / budgetTotal) * 14
// Full budget → radius 20px. Zero budget → radius 6px. Dead → radius 4px, grey.
```

**Edge types and visual encoding:**

| Transaction Type | Color | Animation |
|----------------|-------|-----------|
| Agent → Filecoin (store) | `#00ff88` green | Flowing particle along edge toward Filecoin |
| Agent → Agent (retrieve payment) | `#4488ff` blue | Flowing particle from Consumer to Producer |
| Guardian → Filecoin (re-pin) | `#ff8800` amber | Pulsing dashed line |
| Budget warning | `#ff4444` red | Edge turns red, node border flashes |
| Agent death | All edges | Simultaneously fade to `#333` over 2 seconds |

**The Filecoin storage node:**
Center-gravity attractor. All agents orbit it. Drawn as a large hexagon with `#0090ff` fill, `filecoin.cloud` branded glow ring. When any storage operation happens, the glow intensifies for 1.5 seconds.

### 1.3 How It Updates — SSE, Not WebSocket

Vercel doesn't support persistent WebSocket connections in serverless functions. Use **Server-Sent Events (SSE)** — perfectly suited for one-way server→client streaming, works natively in Next.js route handlers.

```typescript
// app/api/events/route.ts — SSE endpoint
export const runtime = 'nodejs'
export const dynamic = 'force-dynamic'

export async function GET() {
  const stream = new ReadableStream({
    start(controller) {
      const send = (event: AgentEvent) => {
        controller.enqueue(
          `data: ${JSON.stringify(event)}\n\n`
        )
      }

      // Subscribe to event bus
      eventBus.on('agent:store',    send)
      eventBus.on('agent:retrieve', send)
      eventBus.on('agent:pay',      send)
      eventBus.on('agent:died',     send)
      eventBus.on('agent:repin',    send)
    },
  })

  return new Response(stream, {
    headers: {
      'Content-Type':  'text/event-stream',
      'Cache-Control': 'no-cache',
      'Connection':    'keep-alive',
    },
  })
}
```

**Client hook:**
```typescript
// hooks/useAgentEvents.ts
export function useAgentEvents(onEvent: (e: AgentEvent) => void) {
  useEffect(() => {
    const es = new EventSource('/api/events')
    es.onmessage = (msg) => onEvent(JSON.parse(msg.data))
    return () => es.close()
  }, [])
}
```

### 1.4 The Graph Component — Exact Code Structure

```tsx
// components/AgentNetwork.tsx
'use client'
import { useCallback, useRef, useEffect, useState } from 'react'
import dynamic from 'next/dynamic'
import { useAgentEvents } from '@/hooks/useAgentEvents'

// Must be dynamic — react-force-graph uses browser APIs
const ForceGraph2D = dynamic(() => import('react-force-graph-2d'), {
  ssr: false,
})

interface AgentNode {
  id:            string    // 'producer-1', 'consumer-3', 'filecoin'
  type:          'producer' | 'consumer' | 'guardian' | 'filecoin'
  label:         string
  budget:        number    // current USDFC
  budgetTotal:   number    // starting USDFC
  stored:        number    // bytes stored on Filecoin
  alive:         boolean
  pulsing:       boolean   // true for 1.5s after a transaction
  val:           number    // node size — d3 uses this
}

interface AgentLink {
  source:  string
  target:  string
  type:    'store' | 'retrieve' | 'repin' | 'warning'
  active:  boolean  // true for 2s during a transaction
  amount:  number   // USDFC
}

export function AgentNetwork() {
  const graphRef = useRef<any>(null)
  const [graphData, setGraphData] = useState<{
    nodes: AgentNode[]
    links: AgentLink[]
  }>({ nodes: [], links: [] })

  // Listen to SSE events and mutate graph
  useAgentEvents((event) => {
    setGraphData(prev => {
      const next = structuredClone(prev)

      switch (event.type) {
        case 'agent:pay': {
          // Flash the link
          const link = next.links.find(
            l => l.source === event.from && l.target === event.to
          )
          if (link) { link.active = true }

          // Shrink consumer node
          const consumer = next.nodes.find(n => n.id === event.from)
          if (consumer) {
            consumer.budget -= event.amount
            consumer.val = 6 + (consumer.budget / consumer.budgetTotal) * 14
            consumer.pulsing = true
          }

          // Pulse producer
          const producer = next.nodes.find(n => n.id === event.to)
          if (producer) { producer.pulsing = true }

          setTimeout(() => {
            setGraphData(g => {
              const updated = structuredClone(g)
              const l = updated.links.find(l => l.source === event.from && l.target === event.to)
              if (l) l.active = false
              const p = updated.nodes.find(n => n.id === event.from)
              if (p) p.pulsing = false
              return updated
            })
          }, 2000)
          break
        }

        case 'agent:died': {
          const node = next.nodes.find(n => n.id === event.agentId)
          if (node) {
            node.alive   = false
            node.pulsing = false
            node.val     = 4
          }
          // Fade all links to dead node
          next.links.forEach(l => {
            if (l.source === event.agentId || l.target === event.agentId) {
              l.active = false
            }
          })
          break
        }

        case 'agent:store': {
          const producer = next.nodes.find(n => n.id === event.agentId)
          if (producer) {
            producer.stored += event.bytes
            producer.val = Math.min(20, producer.val + 1)
            producer.pulsing = true
          }
          break
        }
      }

      return next
    })
  })

  // Custom node painter — this is where the visual magic lives
  const paintNode = useCallback((node: AgentNode, ctx: CanvasRenderingContext2D, scale: number) => {
    const r = node.val ?? 8
    const x = node.x ?? 0
    const y = node.y ?? 0

    // Glow effect for alive nodes
    if (node.alive && node.pulsing) {
      ctx.shadowBlur  = 20
      ctx.shadowColor = nodeColor(node.type)
    } else {
      ctx.shadowBlur = 0
    }

    // Draw shape based on type
    ctx.beginPath()
    if (node.type === 'filecoin') {
      drawHexagon(ctx, x, y, r + 4)
      ctx.fillStyle = '#0090ff'
    } else if (node.type === 'guardian') {
      drawDiamond(ctx, x, y, r)
      ctx.fillStyle = node.alive ? '#ff8800' : '#333'
    } else {
      ctx.arc(x, y, r, 0, 2 * Math.PI)
      ctx.fillStyle = node.alive ? nodeColor(node.type) : '#333'
    }
    ctx.fill()

    // Budget ring for consumers
    if (node.type === 'consumer' && node.alive) {
      const pct = node.budget / node.budgetTotal
      ctx.beginPath()
      ctx.arc(x, y, r + 2, -Math.PI / 2, -Math.PI / 2 + 2 * Math.PI * pct)
      ctx.strokeStyle = pct < 0.2 ? '#ff4444' : '#4488ff'
      ctx.lineWidth   = 2
      ctx.stroke()
    }

    // Label
    ctx.fillStyle   = node.alive ? '#ffffff' : '#555'
    ctx.font        = `${Math.max(4, 8 / scale)}px "JetBrains Mono", monospace`
    ctx.textAlign   = 'center'
    ctx.fillText(node.label, x, y + r + 8 / scale)

    ctx.shadowBlur = 0
  }, [])

  // Custom link painter — flowing particles
  const paintLink = useCallback((link: AgentLink, ctx: CanvasRenderingContext2D) => {
    if (!link.active) {
      ctx.strokeStyle = '#ffffff10'
      ctx.lineWidth   = 0.5
    } else {
      ctx.strokeStyle = linkColor(link.type)
      ctx.lineWidth   = 1.5
    }
  }, [])

  return (
    <div className="w-full h-full bg-[#080c14]">
      <ForceGraph2D
        ref={graphRef}
        graphData={graphData}
        nodeCanvasObject={paintNode}
        linkCanvasObject={paintLink}
        nodeCanvasObjectMode={() => 'replace'}
        linkCanvasObjectMode={() => 'replace'}
        backgroundColor="#080c14"
        linkDirectionalParticles={(link) => link.active ? 4 : 0}
        linkDirectionalParticleWidth={2}
        linkDirectionalParticleColor={(link) => linkColor(link.type as any)}
        enableNodeDrag={true}
        enableZoomInteraction={true}
        d3AlphaDecay={0.02}
        d3VelocityDecay={0.3}
        onNodeClick={(node) => {
          // Zoom to clicked agent — show detail panel
        }}
      />
    </div>
  )
}

// Helpers
function nodeColor(type: string): string {
  return { producer: '#00ff88', consumer: '#4488ff', guardian: '#ff8800', filecoin: '#0090ff' }[type] ?? '#888'
}
function linkColor(type: string): string {
  return { store: '#00ff88', retrieve: '#4488ff', repin: '#ff8800', warning: '#ff4444' }[type] ?? '#fff'
}
function drawHexagon(ctx: CanvasRenderingContext2D, x: number, y: number, r: number) {
  for (let i = 0; i < 6; i++) {
    const a = (Math.PI / 3) * i - Math.PI / 6
    i === 0 ? ctx.moveTo(x + r * Math.cos(a), y + r * Math.sin(a))
             : ctx.lineTo(x + r * Math.cos(a), y + r * Math.sin(a))
  }
  ctx.closePath()
}
function drawDiamond(ctx: CanvasRenderingContext2D, x: number, y: number, r: number) {
  ctx.moveTo(x, y - r)
  ctx.lineTo(x + r, y)
  ctx.lineTo(x, y + r)
  ctx.lineTo(x - r, y)
  ctx.closePath()
}
```

