## 3. The SDK — `storkeep-sdk`

### Install

```bash
npm install storkeep-sdk
```

### Full API (Track 1 Deliverables Met)

```typescript
import { AgentVault } from 'storkeep-sdk'

const vault = new AgentVault({
  wallet:      agentWallet,        // any EVM wallet / AgentKit
  budget:      '10',               // USDFC starting budget
  network:     'calibration',
  agentType:   'producer',         // 'producer' | 'consumer' | 'guardian'
  policies: {
    maxCostPerStore:    '0.05',     // USDFC — reject if Synapse quotes higher
    minRedundancy:      2,          // always 2-copy replication
    defaultTTL:         '30d',
    pruneWhenBudgetPct: 10,         // prune data when budget < 10%
  },
})

// ── Core lifecycle ──────────────────────────────────────────────────
await vault.store(data, options?)        // Synapse SDK upload → returns CID
await vault.retrieve(cid)               // Synapse SDK download → returns data
await vault.renew(cid)                  // extend storage deal
await vault.prune(cid)                  // delete, recover budget
await vault.pruneAll()                  // prune everything — called on death

// ── Agent economy ───────────────────────────────────────────────────
await vault.announce(cid, pricing)      // list dataset for sale in registry
await vault.discover()                  // find available datasets onchain
await vault.canAfford(price)            // budget check
await vault.collectRevenue()            // sweep incoming USDFC
await vault.chargeRescue(cid, fee)      // Guardian charges owner for re-pin

// ── Availability ────────────────────────────────────────────────────
await vault.checkAvailability(cid)      // ping IPFS gateways → boolean
await vault.repin(cid)                  // Filecoin Pin re-pin for dark data
await vault.getWatchList()             // CIDs this guardian is watching

// ── Budget management ────────────────────────────────────────────────
await vault.getBudget()                 // { remaining, total, percentUsed }
vault.isAlive()                         // false when remaining < MIN_BALANCE
await vault.die()                       // pruneAll() + emit death event onchain

// ── Wallet abstraction (Track 1 requirement) ─────────────────────────
vault.wallet.balance()                  // USDFC on Base / Calibration
vault.wallet.fund(amount)               // top up from any source
```

### Default Storage Policies (Track 1 requirement)

```typescript
// src/policies.ts — exported, overridable
export const DEFAULT_POLICIES: StoragePolicies = {
  maxCostPerStoreUsdfc:  0.10,     // never pay more than this for one upload
  minRedundancy:         2,        // 2-copy replication via Synapse SDK
  defaultTTLDays:        30,       // auto-renew at 25 days remaining
  pruneWhenBudgetPct:    10,       // prune oldest data to free budget
  maxStoredBytes:        100_000_000,  // 100 MB per agent by default
  retryOnFailure:        3,        // retry failed Synapse calls
}
```

